#!/usr/bin/env bash
set -euo pipefail

ROOT="${CODEX_PROFILE_ROOT:-$HOME/.codex-profiles}"
SOURCE="${CODEX_PROFILE_SOURCE:-$HOME/.codex}"

usage() {
  cat <<'EOF'
codex-profile: manage isolated Codex login profiles

Usage:
  cx setup
  cx init <name>
  cx login <name> [--api-key]
  cx status [<name>]
  cx base-url <name> [url|--unset]
  cx delete <name>
  cx run <name> [codex args...]
  cx run <name> resume-from <source> [codex resume args...]
  cx switch <name>

Long form:
  codex-profile setup
  codex-profile init <name> [--no-copy-config]
  codex-profile login <name> [--api-key]
  codex-profile status [<name>]
  codex-profile list
  codex-profile base-url <name> [url|--unset]
  codex-profile delete <name>
  codex-profile run <name> [codex args...]
  codex-profile run <name> resume-from <source> [codex resume args...]
  codex-profile switch <name>
  codex-profile shell-aliases
  codex-profile path <name>

Examples:
  cx setup
  cx init main
  cx login main
  printenv OPENAI_API_KEY | cx login api-openrouter --api-key
  cx run main
  cx run api-openrouter exec "summarize this repo"
  cx run api-openrouter resume-from main
  cx base-url api-openrouter https://api.example.com/v1
  cx base-url api-openrouter --unset
  cx delete old-work
  eval "$(cx switch main)"

Environment:
  CODEX_PROFILE_ROOT     Profile directory root, default: ~/.codex-profiles
  CODEX_PROFILE_SOURCE   Source config directory, default: ~/.codex
EOF
}

die() {
  printf 'codex-profile: %s\n' "$*" >&2
  exit 1
}

need_name() {
  local name="${1:-}"
  validate_name "$name" || die "$REPLY"
}

validate_name() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    REPLY="missing profile name"
    return 1
  fi
  if [[ "$name" == -* ]]; then
    REPLY="invalid profile name: $name"
    return 1
  fi
  if [[ "$name" == "." || "$name" == ".." ]]; then
    REPLY="invalid profile name: $name"
    return 1
  fi
  if [[ "$name" == *"/"* ]]; then
    REPLY="profile name must not contain /"
    return 1
  fi
  if [[ "$name" == *":"* ]]; then
    REPLY="profile name must not contain :"
    return 1
  fi
  return 0
}

profile_dir() {
  local name="$1"
  printf '%s/%s\n' "$ROOT" "$name"
}

base_url_file() {
  local name="$1"
  printf '%s/openai_base_url\n' "$(profile_dir "$name")"
}

profile_base_url() {
  local name="$1"
  local file
  local base_url
  file="$(base_url_file "$name")"
  [[ -f "$file" ]] || return 1
  IFS= read -r base_url < "$file" || true
  [[ -n "${base_url:-}" ]] || return 1
  printf '%s\n' "$base_url"
}

toml_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"\n' "$value"
}

remove_profile_config_key() {
  local name="$1"
  local key="$2"
  local config_file tmp_file
  config_file="$(profile_dir "$name")/config.toml"
  [[ -f "$config_file" ]] || return 0
  tmp_file="$config_file.tmp.$$"
  awk -v key="$key" '
    BEGIN { in_top = 1 }
    /^[[:space:]]*\[/ { in_top = 0 }
    in_top && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" { next }
    { print }
  ' "$config_file" > "$tmp_file"
  mv "$tmp_file" "$config_file"
  chmod 600 "$config_file" 2>/dev/null || true
}

set_profile_config_key() {
  local name="$1"
  local key="$2"
  local value="$3"
  local config_file tmp_file quoted
  config_file="$(profile_dir "$name")/config.toml"
  tmp_file="$config_file.tmp.$$"
  quoted="$(toml_string "$value")"
  remove_profile_config_key "$name" "$key"
  if [[ -f "$config_file" ]]; then
    {
      printf '%s = %s\n' "$key" "$quoted"
      cat "$config_file"
    } > "$tmp_file"
  else
    printf '%s = %s\n' "$key" "$quoted" > "$tmp_file"
  fi
  mv "$tmp_file" "$config_file"
  chmod 600 "$config_file" 2>/dev/null || true
}

sync_profile_base_url_config() {
  local name="$1"
  local base_url
  if base_url="$(profile_base_url "$name")"; then
    set_profile_config_key "$name" "openai_base_url" "$base_url"
  else
    remove_profile_config_key "$name" "openai_base_url"
  fi
}

codex_config_args() {
  local name="$1"
  local base_url
  if base_url="$(profile_base_url "$name")"; then
    printf '%s\n' "-c" "openai_base_url=$(toml_string "$base_url")"
  fi
}

apply_profile_env() {
  local name="$1"
  local base_url
  unset OPENAI_BASE_URL
  if base_url="$(profile_base_url "$name")"; then
    export OPENAI_BASE_URL="$base_url"
  fi
}

prompt_required() {
  local prompt="$1"
  local value
  while true; do
    printf '%s' "$prompt" >&2
    IFS= read -r value
    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
    printf 'Please enter a value.\n' >&2
  done
}

prompt_yes_no() {
  local prompt="$1"
  local default="${2:-yes}"
  local answer
  while true; do
    if [[ "$default" == "yes" ]]; then
      printf '%s [Y/n] ' "$prompt" >&2
    else
      printf '%s [y/N] ' "$prompt" >&2
    fi
    IFS= read -r answer
    case "${answer:-$default}" in
      y|Y|yes|YES) return 0 ;;
      n|N|no|NO) return 1 ;;
      *) printf 'Please answer yes or no.\n' >&2 ;;
    esac
  done
}

prompt_secret() {
  local prompt="$1"
  local value
  if [[ -t 0 ]]; then
    printf '%s' "$prompt" >&2
    IFS= read -r -s value
    printf '\n' >&2
  else
    IFS= read -r value
  fi
  printf '%s\n' "$value"
}

ensure_profile() {
  local name="$1"
  local dir
  dir="$(profile_dir "$name")"
  [[ -d "$dir" ]] || die "profile '$name' does not exist. Run: codex-profile init $name"
}

init_profile() {
  local name="$1"
  local copy_config="${2:-yes}"
  local dir
  dir="$(profile_dir "$name")"
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true

  if [[ "$copy_config" == "yes" && -f "$SOURCE/config.toml" && ! -e "$dir/config.toml" ]]; then
    cp "$SOURCE/config.toml" "$dir/config.toml"
    chmod 600 "$dir/config.toml" 2>/dev/null || true
    printf 'Initialized %s and copied config.toml from %s\n' "$dir" "$SOURCE"
  else
    printf 'Initialized %s\n' "$dir"
  fi
}

login_profile() {
  local name="$1"
  local mode="${2:-account}"
  local dir
  dir="$(profile_dir "$name")"
  [[ -d "$dir" ]] || init_profile "$name" >/dev/null
  apply_profile_env "$name"

  if [[ "$mode" == "api-key" ]]; then
    CODEX_HOME="$dir" codex login --with-api-key
  else
    CODEX_HOME="$dir" codex login
  fi
}

status_profile() {
  local name="$1"
  local dir
  local base_url
  dir="$(profile_dir "$name")"
  printf '%s  %s\n' "$name" "$dir"
  if base_url="$(profile_base_url "$name")"; then
    printf 'OPENAI_BASE_URL=%s\n' "$base_url"
  else
    printf 'OPENAI_BASE_URL=<default>\n'
  fi
  apply_profile_env "$name"
  if CODEX_HOME="$dir" codex login status; then
    return 0
  fi
  return 0
}

set_base_url() {
  local name="$1"
  local value="${2:-}"
  local file
  local base_url
  ensure_profile "$name"
  file="$(base_url_file "$name")"

  if [[ -z "$value" ]]; then
    if base_url="$(profile_base_url "$name")"; then
      printf '%s\n' "$base_url"
    else
      printf '<default>\n'
    fi
    return 0
  fi

  if [[ "$value" == "--unset" || "$value" == "--default" ]]; then
    rm -f -- "$file"
    sync_profile_base_url_config "$name"
    printf 'Unset base URL for profile %s; it will use the default endpoint.\n' "$name"
    return 0
  fi

  [[ "$value" != *$'\n'* ]] || die "OPENAI_BASE_URL must be a single line"
  printf '%s\n' "$value" > "$file"
  chmod 600 "$file" 2>/dev/null || true
  sync_profile_base_url_config "$name"
  printf 'Set base URL for profile %s\n' "$name"
}

setup_profile() {
  local name
  local suffix
  local profile_type
  local copy_config="yes"
  local base_url
  local api_key
  local dir

  printf 'Codex profile setup\n'
  printf '\n'

  printf 'Profile type:\n'
  printf '  1) ChatGPT account profile\n'
  printf '  2) API-key profile\n'
  printf '  3) Empty profile / skip login\n'
  while true; do
    printf 'Choose [1-3]: '
    IFS= read -r profile_type
    case "${profile_type:-1}" in
      1|2|3) break ;;
      *) printf 'Please choose 1, 2, or 3.\n' >&2 ;;
    esac
  done

  if [[ "${profile_type:-1}" == "2" ]]; then
    printf '\n'
    printf 'API profiles are named with the api- prefix.\n'
    printf 'Enter only the suffix, for example: openrouter -> api-openrouter.\n'
    while true; do
      suffix="$(prompt_required "API profile suffix: ")"
      name="api-$suffix"
      if validate_name "$suffix" && validate_name "$name"; then
        break
      fi
      printf '%s\n' "$REPLY" >&2
    done
  else
    while true; do
      name="$(prompt_required "Profile name: ")"
      if validate_name "$name"; then
        break
      fi
      printf '%s\n' "$REPLY" >&2
    done
  fi

  printf '\n'
  printf 'config.toml stores non-login Codex settings such as model, sandbox,\n'
  printf 'approval policy, MCP servers, and other CLI preferences.\n'
  printf 'Copy it if this profile should reuse your current Codex behavior.\n'
  printf 'Skip it for a clean profile with default settings.\n'
  printf '\n'
  if ! prompt_yes_no "Copy config.toml from $SOURCE?" "yes"; then
    copy_config="no"
  fi

  init_profile "$name" "$copy_config"

  printf 'OpenAI-compatible base URL (leave blank for default): '
  IFS= read -r base_url
  if [[ -n "$base_url" ]]; then
    set_base_url "$name" "$base_url"
  else
    printf 'Using default base URL.\n'
  fi

  printf '\n'
  case "${profile_type:-1}" in
    1)
      if prompt_yes_no "Log in with a ChatGPT account now?" "yes"; then
        login_profile "$name" "account"
      fi
      ;;
    2)
      if prompt_yes_no "Log in with an API key now?" "yes"; then
        dir="$(profile_dir "$name")"
        api_key="$(prompt_secret "OpenAI API key: ")"
        [[ -n "$api_key" ]] || die "missing API key"
        apply_profile_env "$name"
        printf '%s\n' "$api_key" | CODEX_HOME="$dir" codex login --with-api-key
      fi
      ;;
    3)
      printf 'Skipping login.\n'
      ;;
  esac

  printf '\n'
  printf 'Profile %s is ready.\n' "$name"
  printf 'Run it with: cx run %s\n' "$name"
}

list_profiles() {
  mkdir -p "$ROOT"
  local found=0
  local dir name
  for dir in "$ROOT"/*; do
    [[ -d "$dir" ]] || continue
    found=1
    name="$(basename "$dir")"
    status_profile "$name"
    printf '\n'
  done
  [[ "$found" == 1 ]] || printf 'No profiles in %s\n' "$ROOT"
}

delete_profile() {
  local name="$1"
  local dir referrers referrer
  dir="$(profile_dir "$name")"
  ensure_profile "$name"

  referrers="$(profiles_referencing_sessions "$name")"
  if [[ -n "$referrers" ]]; then
    printf "codex-profile: cannot delete profile '%s'; its sessions are referenced by:\n" "$name" >&2
    while IFS= read -r referrer; do
      [[ -n "$referrer" ]] && printf '  %s\n' "$referrer" >&2
    done <<< "$referrers"
    die "repoint those profiles before deleting '$name'"
  fi

  rm -rf -- "$dir"
  printf 'Deleted profile %s from %s\n' "$name" "$dir"
}

next_backup_path() {
  local path="$1"
  local stamp backup i
  stamp="$(date +%Y%m%d%H%M%S)"
  backup="${path}.local.${stamp}"
  i=1
  while [[ -e "$backup" || -L "$backup" ]]; do
    backup="${path}.local.${stamp}.${i}"
    i=$((i + 1))
  done
  printf '%s\n' "$backup"
}

link_target_path() {
  local path="$1"
  local link
  link="$(readlink "$path")" || return 1
  if [[ "$link" == /* ]]; then
    printf '%s\n' "$link"
  else
    printf '%s/%s\n' "$(dirname "$path")" "$link"
  fi
}

sessions_link_reaches() {
  local start="$1"
  local target="$2"
  local current="$start"
  local depth=0

  while [[ -L "$current" ]]; do
    [[ "$current" == "$target" ]] && return 0
    current="$(link_target_path "$current")" || return 1
    [[ "$current" == "$target" ]] && return 0
    depth=$((depth + 1))
    [[ "$depth" -lt 40 ]] || return 2
  done

  return 1
}

profiles_referencing_sessions() {
  local name="$1"
  local target_sessions candidate candidate_name link_check
  target_sessions="$(profile_dir "$name")/sessions"

  for candidate in "$ROOT"/*/sessions; do
    [[ -L "$candidate" ]] || continue
    candidate_name="$(basename "$(dirname "$candidate")")"
    [[ "$candidate_name" != "$name" ]] || continue

    link_check=0
    sessions_link_reaches "$candidate" "$target_sessions" || link_check=$?
    if [[ "$link_check" -eq 0 ]]; then
      printf '%s\n' "$candidate_name"
    fi
  done
  return 0
}

shared_profile_name() {
  local first="$1"
  local second="$2"
  if [[ "$second" < "$first" ]]; then
    first="$2"
    second="$1"
  fi
  printf 'shared-%s-%s\n' "$first" "$second"
}

point_sessions_at() {
  local name="$1"
  local shared_sessions="$2"
  local sessions backup current_link

  sessions="$(profile_dir "$name")/sessions"
  if [[ -L "$sessions" ]]; then
    current_link="$(link_target_path "$sessions")"
    if [[ "$current_link" == "$shared_sessions" ]]; then
      return 0
    fi
    backup="$(next_backup_path "$sessions")"
    mv "$sessions" "$backup"
    printf 'Moved existing sessions link for %s to %s\n' "$name" "$backup"
  elif [[ -e "$sessions" ]]; then
    backup="$(next_backup_path "$sessions")"
    mv "$sessions" "$backup"
    printf 'Moved existing sessions for %s to %s\n' "$name" "$backup"
  fi

  ln -s "$shared_sessions" "$sessions"
  printf 'Profile %s now shares sessions from %s\n' "$name" "$shared_sessions"
}

create_shared_sessions_for_loop() {
  local target="$1"
  local source="$2"
  local target_sessions="$3"
  local source_sessions="$4"
  local shared_name shared_dir shared_sessions

  shared_name="$(shared_profile_name "$target" "$source")"
  shared_dir="$(profile_dir "$shared_name")"
  shared_sessions="$shared_dir/sessions"

  if [[ ! -e "$shared_sessions" && ! -L "$shared_sessions" ]] \
    && [[ ! ( -e "$target_sessions" && ! -L "$target_sessions" ) ]] \
    && [[ ! ( -e "$source_sessions" && ! -L "$source_sessions" ) ]]; then
    die "cannot consolidate sessions for '$target' and '$source': neither profile owns a real sessions directory"
  fi

  mkdir -p "$shared_dir"
  chmod 700 "$shared_dir" 2>/dev/null || true

  if [[ -e "$shared_sessions" || -L "$shared_sessions" ]]; then
    [[ -d "$shared_sessions" ]] || die "shared profile '$shared_name' sessions path is not a directory"
    if [[ ( -e "$target_sessions" && ! -L "$target_sessions" ) ]] \
      || [[ ( -e "$source_sessions" && ! -L "$source_sessions" ) ]]; then
      die "shared profile '$shared_name' already exists alongside real sessions; reconcile them manually"
    fi
    printf 'Using existing shared profile %s\n' "$shared_name"
  elif [[ -e "$target_sessions" && ! -L "$target_sessions" ]]; then
    mv "$target_sessions" "$shared_sessions"
    printf 'Created shared profile %s from %s sessions\n' "$shared_name" "$target"
  elif [[ -e "$source_sessions" && ! -L "$source_sessions" ]]; then
    mv "$source_sessions" "$shared_sessions"
    printf 'Created shared profile %s from %s sessions\n' "$shared_name" "$source"
  fi

  point_sessions_at "$target" "$shared_sessions"
  point_sessions_at "$source" "$shared_sessions"
}

resume_from_profile() {
  local target="$1"
  local source="$2"
  shift 2 || true
  local target_dir source_dir target_sessions source_sessions current_link backup link_check source_label
  local config_args=()

  [[ "$target" != "$source" ]] || die "source and target profiles must be different"
  ensure_profile "$target"
  ensure_profile "$source"

  target_dir="$(profile_dir "$target")"
  source_dir="$(profile_dir "$source")"
  target_sessions="$target_dir/sessions"
  source_sessions="$source_dir/sessions"
  source_label="$source"

  [[ -e "$source_sessions" || -L "$source_sessions" ]] || die "profile '$source' has no sessions directory"
  if [[ -L "$source_sessions" && ! -e "$source_sessions" ]]; then
    die "profile '$source' sessions link is dangling or cyclic; repair it before using resume-from"
  fi
  [[ -d "$source_sessions" ]] || die "profile '$source' sessions path is not a directory"

  link_check=0
  sessions_link_reaches "$source_sessions" "$target_sessions" || link_check=$?
  if [[ "$link_check" -eq 0 ]]; then
    printf "Detected that resuming from '%s' would create a sessions link loop with '%s'.\n" "$source" "$target"
    create_shared_sessions_for_loop "$target" "$source" "$target_sessions" "$source_sessions"
    source_label="$(shared_profile_name "$target" "$source")"
    source_sessions="$(profile_dir "$source_label")/sessions"
  elif [[ "$link_check" -eq 2 ]]; then
    die "cannot resume from '$source': its sessions link chain appears to be a loop"
  fi
  [[ -d "$source_sessions" ]] || die "profile '$source' sessions path is not a directory"

  if [[ -L "$target_sessions" ]]; then
    current_link="$(readlink "$target_sessions")"
    if [[ "$current_link" == "$source_sessions" ]]; then
      printf 'Profile %s already shares sessions from %s\n' "$target" "$source_label"
    else
      backup="$(next_backup_path "$target_sessions")"
      mv "$target_sessions" "$backup"
      ln -s "$source_sessions" "$target_sessions"
      printf 'Moved existing sessions link to %s\n' "$backup"
      printf 'Profile %s now shares sessions from %s\n' "$target" "$source_label"
    fi
  else
    if [[ -e "$target_sessions" ]]; then
      backup="$(next_backup_path "$target_sessions")"
      mv "$target_sessions" "$backup"
      printf 'Moved existing sessions to %s\n' "$backup"
    fi
    ln -s "$source_sessions" "$target_sessions"
    printf 'Profile %s now shares sessions from %s\n' "$target" "$source_label"
  fi

  sync_profile_base_url_config "$target"
  apply_profile_env "$target"
  if [[ -f "$(base_url_file "$target")" ]]; then
    while IFS= read -r config_arg; do
      config_args+=("$config_arg")
    done < <(codex_config_args "$target")
  fi
  CODEX_HOME="$target_dir" exec codex ${config_args[@]+"${config_args[@]}"} resume --all "$@"
}

run_profile() {
  local name="$1"
  shift || true
  local dir
  local config_args=()
  dir="$(profile_dir "$name")"
  ensure_profile "$name"

  if [[ "${1:-}" == "resume-from" ]]; then
    shift
    local source="${1:-}"
    need_name "$source"
    shift || true
    resume_from_profile "$name" "$source" "$@"
  fi

  sync_profile_base_url_config "$name"
  apply_profile_env "$name"
  if [[ -f "$(base_url_file "$name")" ]]; then
    while IFS= read -r config_arg; do
      config_args+=("$config_arg")
    done < <(codex_config_args "$name")
  fi
  CODEX_HOME="$dir" exec codex ${config_args[@]+"${config_args[@]}"} "$@"
}

switch_profile() {
  local name="$1"
  local dir
  local base_url
  dir="$(profile_dir "$name")"
  ensure_profile "$name"
  printf 'export CODEX_HOME=%q\n' "$dir"
  if base_url="$(profile_base_url "$name")"; then
    printf 'export OPENAI_BASE_URL=%q\n' "$base_url"
  else
    printf 'unset OPENAI_BASE_URL\n'
  fi
}

shell_aliases() {
  cat <<'EOF'
# Optional aliases for ~/.zshrc.
alias cmain='CODEX_HOME=$HOME/.codex-profiles/main codex'
alias cwork='CODEX_HOME=$HOME/.codex-profiles/work codex'
alias capi='CODEX_HOME=$HOME/.codex-profiles/api-openrouter codex'
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  setup|wizard|configure)
    setup_profile
    ;;
  init|new)
    name="${1:-}"
    need_name "$name"
    shift || true
    copy_config="yes"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --no-copy-config) copy_config="no" ;;
        *) die "unknown option for init: $1" ;;
      esac
      shift
    done
    init_profile "$name" "$copy_config"
    ;;
  login)
    name="${1:-}"
    need_name "$name"
    shift || true
    mode="account"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --api-key) mode="api-key" ;;
        *) die "unknown option for login: $1" ;;
      esac
      shift
    done
    login_profile "$name" "$mode"
    ;;
  status|ls)
    if [[ "${1:-}" == "--all" || $# -eq 0 ]]; then
      list_profiles
    else
      need_name "$1"
      ensure_profile "$1"
      status_profile "$1"
    fi
    ;;
  list)
    list_profiles
    ;;
  base-url|openai-base-url)
    name="${1:-}"
    need_name "$name"
    shift || true
    [[ $# -le 1 ]] || die "usage: codex-profile base-url <name> [url|--unset]"
    set_base_url "$name" "${1:-}"
    ;;
  delete|remove|rm)
    name="${1:-}"
    need_name "$name"
    delete_profile "$name"
    ;;
  run|use)
    name="${1:-}"
    need_name "$name"
    shift || true
    run_profile "$name" "$@"
    ;;
  switch)
    name="${1:-}"
    need_name "$name"
    switch_profile "$name"
    ;;
  path)
    name="${1:-}"
    need_name "$name"
    printf '%s\n' "$(profile_dir "$name")"
    ;;
  shell-aliases|aliases)
    shell_aliases
    ;;
  *)
    die "unknown command: $cmd"
    ;;
esac
